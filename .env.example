# Copia este fichero a .env.local y rellena los valores
# El .env.local NO se commitea (está en .gitignore)

# Supabase — sacar de https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Holded API — sólo para scripts locales. En producción se setea como secret de la Edge Function holded-sync.
# Generar en Holded: Settings > Developers > New API Key. NO usar en frontend (R/W total).
HOLDED_API_KEY=
